{
  "manifest_version": 3,
  "name": "WhatsApp Sound Notify",
  "version": "1.0.0",
  "description": "Som personalizado para notificações de novas mensagens no WhatsApp Web.",

  "permissions": [
    "storage",
    "offscreen"
  ],

  "host_permissions": [
    "https://web.whatsapp.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["logger.js", "content.js"],
      "run_at": "document_idle"
    }
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  }
}
